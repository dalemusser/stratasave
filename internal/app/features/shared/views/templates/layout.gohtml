{{ define "layout" }}
<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
  <head>
    <meta charset="UTF-8" />
    <title>Stratalog</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.5"></script>
  </head>

  <body class="h-full">
    <main id="content" class="min-h-screen p-6">
      {{ block "content" . }}{{ end }}
    </main>
  </body>
</html>
{{ end }}